<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ProcessEventPics.Maui"
             xmlns:converters="clr-namespace:ProcessEventPics.Maui.Converters"
             x:Class="ProcessEventPics.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:EventTypeToLabelConverter x:Key="EventTypeToLabelConverter" />
            <converters:SelectedItemBackgroundConverter x:Key="SelectedItemBackgroundConverter" />
            <converters:SelectedItemBorderConverter x:Key="SelectedItemBorderConverter" />
            <converters:NotNullConverter x:Key="NotNullConverter" />
            <converters:IsZeroConverter x:Key="IsZeroConverter" />
            <converters:BrandColorConverter x:Key="BrandColorConverter" />
            <converters:SelectedItemTextColorConverter x:Key="SelectedItemTextColorConverter" />
            <converters:SelectedLocationTextColorConverter x:Key="SelectedLocationTextColorConverter" />
            <converters:HideWhenSelectedConverter x:Key="HideWhenSelectedConverter" />
            <converters:IsFavoriteConverter x:Key="IsFavoriteConverter" />
            <converters:FavoriteStarTextConverter x:Key="FavoriteStarTextConverter" />
            <converters:ContainsConverter x:Key="ContainsConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
